{
  "name": "@solsentry/mcp",
  "version": "0.2.0",
  "description": "SolSentry MCP server + TypeScript SDK — Solana threat intelligence. Operator risk, token risk, rug pull detection via mainnet monitoring.",
  "keywords": [
    "solana",
    "mcp",
    "model-context-protocol",
    "threat-intelligence",
    "rug-pull",
    "security",
    "defi",
    "claude",
    "cursor",
    "sdk",
    "typescript"
  ],
  "homepage": "https://solsentry.app",
  "bugs": "https://github.com/solsentryai/solsentry-mcp/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solsentryai/solsentry-mcp.git"
  },
  "license": "MIT",
  "author": "SolSentry <solanasentryai@gmail.com>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "bin": {
    "solsentry-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "skills",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "test": "node --test dist/**/*.test.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
